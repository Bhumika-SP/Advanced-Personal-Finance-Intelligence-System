<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Budgets</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      font-family: 'Poppins', sans-serif;
    }
  </style>
  <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-app text-white flex h-screen">
  <div class="flex min-h-screen w-full">
    <%- include('partials/sidebar', { activeTab: 'budgets' }) %>
      <main class="flex-1 p-8 overflow-y-auto animate-fade-slide-up delay-100">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-semibold">Budgets - <%= period %>
          </h2>
          <a href="/budgets/new?period=<%= encodeURIComponent(period) %>" class="btn-primary px-5 py-2 rounded">➕ New
            Budget</a>
        </div>

        <div class="bg-card-custom card-hover p-4 rounded mb-6">
          <form method="GET" action="/budgets" class="flex items-center gap-3">
            <label>Period</label>
            <input type="month" name="period" value="<%= period %>" class="p-2 rounded bg-opacity-20" />
            <button type="submit" class="btn-secondary px-4 py-2 rounded">Go</button>
          </form>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full bg-card-custom card-hover rounded">
            <thead>
              <tr class="text-gray-300 sticky top-0 z-20">
                <th class="py-3 px-4 cursor-pointer" data-sort="text">Category</th>
                <th class="py-3 px-4 cursor-pointer" data-sort="number">Target</th>
                <th class="py-3 px-4 cursor-pointer" data-sort="number">Spent</th>
                <th class="py-3 px-4 cursor-pointer" data-sort="number">Remaining</th>
                <th class="py-3 px-4 cursor-pointer" data-sort="number">Progress</th>
                <th class="py-3 px-4">Actions</th>
              </tr>
            </thead>
            <tbody id="bud-tbody">
              <% if (rows && rows.length) { %>
                <% rows.forEach((r, i)=> { %>
                  <tr class="border-t border-gray-700 table-row-hover" data-cat="<%= r.budget.category %>"
                    data-target="<%= r.budget.amount %>" data-spent="<%= r.spent %>" data-rem="<%= r.remaining %>"
                    data-prog="<%= r.progress %>">
                    <td class="py-3 px-4">
                      <%= r.budget.category %>
                        <% if (r.overspend && r.budget.alertsOn) { %><span
                            class="text-red-400 flex items-center gap-1"><i data-lucide="alert-circle"
                              class="w-3 h-3"></i> Overspent</span>
                          <% } %>
                    </td>
                    <td class="py-3 px-4">₹<%= r.budget.amount %>
                    </td>
                    <td class="py-3 px-4">₹<%= r.spent %>
                    </td>
                    <td class="py-3 px-4">₹<%= r.remaining %>
                    </td>
                    <td class="py-3 px-4">
                      <div
                        class="w-full bg-opacity-20 backdrop-blur-md border border-white border-opacity-10 h-3 rounded">
                        <div class="h-3 rounded <%= r.overspend ? 'bg-red-500' : 'bg-green-500' %>"
                          style="width: <%= r.progress %>%"></div>
                      </div>
                    </td>
                    <td class="py-3 px-4 space-x-3">
                      <a href="/budgets/edit/<%= r.budget._id %>" class="text-blue-400 px-2 py-1 inline-block"><i data-lucide="edit" class="w-4 h-4 inline-block align-text-bottom mr-1"></i> Edit</a>
                  <form action="/budgets/delete/<%= r.budget._id %>" method="POST" class="inline" onsubmit="return confirm('Delete budget?')">
                    <button type="submit" class="text-red-400 px-2 py-1 rounded"><i data-lucide="trash-2" class="w-4 h-4 inline-block align-text-bottom mr-1"></i> Delete</button>
                  </form>
                    </td>
                  </tr>
                  <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="6" class="py-4 text-center text-gray-400">No budgets configured for this period.
                        </td>
                      </tr>
                      <% } %>
            </tbody>
          </table>
        </div>
        <script>
          // Column sorting
          const tbody = document.getElementById('bud-tbody');
          function val(tr, key) { return tr.getAttribute(key) || ''; }
          function sortBy(key, type, asc) {
            const rows = Array.from(tbody.querySelectorAll('tr'));
            rows.sort((a, b) => {
              const va = val(a, key); const vb = val(b, key);
              if (type === 'number') return (Number(va) - Number(vb)) * (asc ? 1 : -1);
              return String(va).localeCompare(String(vb)) * (asc ? 1 : -1);
            });
            rows.forEach(r => tbody.appendChild(r));
          }
          const map = ['data-cat', 'data-target', 'data-spent', 'data-rem', 'data-prog'];
          document.querySelectorAll('th[data-sort]').forEach((th, i) => {
            let asc = true;
            th.addEventListener('click', () => { sortBy(map[i], th.getAttribute('data-sort'), asc); asc = !asc; });
          });
        </script>
      </main>
  </div>




  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>

</html>