<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ask Your Finances | Expensio</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
    :root {
      --primary: #3b82f6;
      --primary-hover: #2563eb;
      --bg-dark: #111827;
      --bg-darker: #0f172a;
      --bg-card: #1e293b;
      --text-primary: #f3f4f6;
      --text-secondary: #9ca3af;
      --border-color: #374151;
    }
    
    body {
      background-color: #111827;
      color: #f3f4f6;
      min-height: 100vh;
    }
    
    .message-user {
      background-color: #1f2937;
      border-left: 4px solid #3b82f6;
      color: #f3f4f6;
      margin: 0.5rem 0;
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
    }
    
    .message-ai {
      background-color: #1f2937;
      border-left: 4px solid #8b5cf6;
      color: #f3f4f6;
      margin: 0.5rem 0;
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
    }
    
    .nav-link {
      display: flex;
      align-items: center;
      padding: 0.5rem 1rem;
      border-radius: 0.375rem;
      transition: all 0.2s;
      color: #d1d5db;
      margin: 0.25rem 0;
      font-size: 0.875rem;
    }
    
    .nav-link:hover {
      background-color: #374151;
      color: #60a5fa;
    }
    
    .nav-link.active {
      background-color: #374151;
      color: #60a5fa;
      font-weight: 500;
    }
    
    .chat-history-item {
      padding: 0.75rem 1rem;
      margin: 0.25rem 0;
      border-radius: 0.375rem;
      cursor: pointer;
      transition: all 0.2s;
      font-size: 0.875rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .chat-history-item:hover {
      background-color: #374151;
    }
    
    .chat-history-item.active {
      background-color: #1e40af;
      color: white;
    }
    
    .btn-primary {
      background-color: #2563eb;
      color: white;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 0.375rem;
      transition: background-color 0.2s;
    }
    
    .btn-primary:hover {
      background-color: #1d4ed8;
    }
    
    .btn-secondary {
      background-color: #374151;
      color: #e5e7eb;
      font-weight: 500;
      padding: 0.5rem 1rem;
      border-radius: 0.375rem;
      transition: all 0.2s;
    }
    
    .btn-secondary:hover {
      background-color: #4b5563;
    }
    
    .input-field {
      width: 100%;
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
      background-color: #1f2937;
      border: 1px solid #374151;
      color: #f3f4f6;
      transition: all 0.2s;
      font-size: 0.95rem;
    }
    
    .input-field:focus {
      border-color: #3b82f6;
      outline: none;
      box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
    }
    
    .chat-container {
      display: grid;
      grid-template-columns: 280px 1fr;
      height: 100vh;
    }
    
    .chat-sidebar {
      background-color: #1f2937;
      border-right: 1px solid #374151;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
    }
    
    .chat-main {
      display: flex;
      flex-direction: column;
      height: 100vh;
    }
    
    .chat-header {
      padding: 1.25rem 2rem;
      border-bottom: 1px solid #374151;
      background-color: #111827;
    }
    
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem 2rem;
    }
    
    .chat-input-container {
      padding: 1.25rem 2rem;
      border-top: 1px solid #374151;
      background-color: #111827;
    }
    
    .quick-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1rem 0;
    }
    
    .quick-action-btn {
      background-color: #1f2937;
      color: #e5e7eb;
      border: 1px solid #374151;
      border-radius: 0.375rem;
      padding: 0.4rem 0.75rem;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .quick-action-btn:hover {
      background-color: #374151;
      border-color: #4b5563;
    }
  </style>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen">
  <div class="flex h-screen">
    <!-- Sidebar Navigation -->
    <div class="w-64 bg-gray-800 text-gray-100 flex flex-col h-full">
      <div class="p-4 border-b border-gray-700">
        <h1 class="text-xl font-bold">Expensio</h1>
      </div>
      <nav class="flex-1 p-4 space-y-2">
        <a href="/dashboard" class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
          <i class="fas fa-tachometer-alt mr-3"></i> Dashboard
        </a>
        <a href="/expenses" class="nav-link <%= currentPath === '/expenses' ? 'active' : '' %>">
          <i class="fas fa-receipt mr-3"></i> Expenses
        </a>
        <a href="/trips" class="nav-link <%= currentPath === '/trips' ? 'active' : '' %>">
          <i class="fas fa-suitcase-rolling mr-3"></i> Trips
        </a>
        <a href="/income" class="nav-link <%= currentPath === '/income' ? 'active' : '' %>">
          <i class="fas fa-money-bill-wave mr-3"></i> Income
        </a>
        <a href="/chat" class="nav-link <%= currentPath === '/chat' ? 'active' : '' %>">
          <i class="fas fa-comment-dots mr-3"></i> Chat with AI
        </a>
      </nav>
      <div class="p-4 border-t border-gray-700">
        <a href="/profile" class="flex items-center">
          <div class="h-8 w-8 rounded-full bg-gray-600 flex items-center justify-center mr-3">
            <i class="fas fa-user text-sm"></i>
          </div>
          <span>Profile</span>
        </a>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Search Bar -->
      <div class="bg-gray-800 p-4 border-b border-gray-700">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-2xl font-bold text-white mb-2">Ask Your Finances</h1>
          <p class="text-sm text-gray-400 mb-4">Get instant insights about your spending and budgets</p>
          
          <form id="chat-form" class="relative">
            <div class="relative">
              <input 
                id="chat-input"
                type="text" 
                name="text"
                placeholder="Ask me anything about your finances..." 
                class="w-full px-4 py-3 pl-12 pr-20 bg-gray-700 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                autocomplete="off"
                required
              >
              <div class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">
                <i class="fas fa-search"></i>
              </div>
              <button type="submit" class="absolute right-2 top-1/2 transform -translate-y-1/2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-md text-sm font-medium transition-colors">
                <i class="fas fa-paper-plane mr-1"></i> Send
              </button>
            </div>
          </form>
          
          <!-- Quick Suggestions -->
          <div class="mt-3">
            <p class="text-xs text-gray-400 mb-1">Try asking:</p>
            <div class="flex flex-wrap gap-2">
              <button type="button" data-q="How much did I spend this month?" class="text-xs bg-gray-700 hover:bg-gray-600 text-gray-200 px-3 py-1.5 rounded-full transition-colors">
                How much did I spend this month?
              </button>
              <button type="button" data-q="What are my top spending categories?" class="text-xs bg-gray-700 hover:bg-gray-600 text-gray-200 px-3 py-1.5 rounded-full transition-colors">
                Top spending categories
              </button>
              <button type="button" data-q="Show my monthly budget status" class="text-xs bg-gray-700 hover:bg-gray-600 text-gray-200 px-3 py-1.5 rounded-full transition-colors">
                Monthly budget status
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Chat Messages -->
      <div class="flex-1 overflow-y-auto p-6" id="chat-messages">
        <div class="max-w-4xl mx-auto">
          <!-- Welcome Message -->
          <div class="message-ai bg-gray-800 rounded-lg p-4 mb-4" id="welcome-message">
            <div class="flex items-start">
              <div class="flex-shrink-0 mr-3">
                <div class="h-8 w-8 rounded-full flex items-center justify-center text-gray-900" style="background: var(--accent-purple)">
                <i data-lucide="bot" class="text-sm"></i>
              </div>
              </div>
              <div class="flex-1">
                <div class="text-sm text-gray-400 mb-1">
                  <span class="font-medium">Expensio AI</span>
                  <span class="text-xs text-gray-500 ml-2">Just now</span>
                </div>
                <div class="text-gray-100">
                  <p>Hello! I'm your Expensio AI assistant. Ask me anything about your finances.</p>
                  <p class="mt-2">You can ask about:</p>
                  <ul class="list-disc list-inside mt-1 text-gray-300 space-y-1">
                    <li>Your spending this month</li>
                    <li>Budget status and recommendations</li>
                    <li>Expense categories and trends</li>
                    <li>Savings progress</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Dynamic Messages Will Appear Here -->
          <div id="current-chat"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const chatForm = document.getElementById('chat-form');
      const chatInput = document.getElementById('chat-input');
      const currentChat = document.getElementById('current-chat');
      const welcomeMessage = document.getElementById('welcome-message');

      // Function to add a message to the chat
      function addMessageToChat(role, text) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message-${role} ${role === 'user' ? 'bg-gray-700' : 'bg-gray-800'} rounded-lg p-4 mb-4`;
        messageDiv.innerHTML = `
          <div class="flex items-start">
            <div class="flex-shrink-0 mr-3">
              <div class="h-8 w-8 rounded-full ${role === 'user' ? 'bg-blue-600' : 'bg-purple-600'} flex items-center justify-center text-white">
                <i class="fas ${role === 'user' ? 'fa-user' : 'fa-robot'} text-sm"></i>
              </div>
            </div>
            <div class="flex-1">
              <div class="text-sm text-gray-400 mb-1">
                <span class="font-medium">${role === 'user' ? 'You' : 'Expensio AI'}</span>
                <span class="text-xs text-gray-500 ml-2">${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
              </div>
              <div class="text-gray-100 whitespace-pre-wrap">${text}</div>
            </div>
          </div>
        `;
        return messageDiv;
      }

      // Handle chat form submission
      if (chatForm) {
        chatForm.addEventListener('submit', async function(e) {
          e.preventDefault();
          const message = chatInput.value.trim();
          
          if (!message) return;
          
          // Hide welcome message after first message
          if (welcomeMessage) {
            welcomeMessage.style.display = 'none';
          }
          
          // Clear previous chat and add user message
          currentChat.innerHTML = '';
          currentChat.appendChild(addMessageToChat('user', message));
          
          // Clear input
          chatInput.value = '';
          
          // Show loading state
          const loadingId = 'loading-' + Date.now();
          const loadingDiv = document.createElement('div');
          loadingDiv.id = loadingId;
          loadingDiv.className = 'message-ai bg-gray-800 rounded-lg p-4 mb-4';
          loadingDiv.innerHTML = `
            <div class="flex items-center">
              <div class="animate-pulse flex space-x-4">
                <div class="h-2 bg-gray-700 rounded w-3/4"></div>
              </div>
            </div>
          `;
          currentChat.appendChild(loadingDiv);
          currentChat.scrollIntoView({ behavior: 'smooth', block: 'end' });
          
          try {
            // Send message to server
            const response = await fetch('/chat/message', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
              },
              body: `text=${encodeURIComponent(message)}`
            });
            
            // Remove loading message
            const loadingEl = document.getElementById(loadingId);
            if (loadingEl) loadingEl.remove();
            
            // Get response data
            const data = await response.json();
            if (data.success && data.reply) {
              currentChat.appendChild(addMessageToChat('assistant', data.reply));
            } else {
              throw new Error('Failed to get response');
            }
          } catch (error) {
            console.error('Error sending message:', error);
            // Remove loading message on error
            const loadingEl = document.getElementById(loadingId);
            if (loadingEl) loadingEl.remove();
            
            // Show error message
            currentChat.appendChild(addMessageToChat('assistant', 'Sorry, something went wrong. Please try again.'));
          }
          
          // Scroll to bottom of chat
          currentChat.scrollIntoView({ behavior: 'smooth', block: 'end' });
        });
      }

      // Handle quick suggestion clicks
      document.querySelectorAll('.quick-suggestion').forEach(button => {
        button.addEventListener('click', function() {
          chatInput.value = this.textContent;
          chatInput.focus();
        });
      });
    });
    
    // Handle Enter key for new line with Shift+Enter
    if (chatInput) {
      chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          chatForm.dispatchEvent(new Event('submit'));
        }
      });
    }
    
    // Helper function to add a message to the chat
    function addMessageToChat(role, text) {
      if (!chatMessages) return;
      
      const messageDiv = document.createElement('div');
      messageDiv.className = `message-${role} ${role === 'user' ? 'bg-gray-700' : 'bg-gray-800'} rounded-lg p-4 mb-4`;
      
      const isAI = role === 'assistant';
      const icon = isAI ? 'fa-robot' : 'fa-user';
      const bgColor = isAI ? 'bg-purple-600' : 'bg-blue-600';
      const name = isAI ? 'Expensio AI' : 'You';
      
      messageDiv.innerHTML = `
        <div class="flex items-start">
          <div class="flex-shrink-0 mr-3">
            <div class="h-8 w-8 rounded-full ${bgColor} flex items-center justify-center text-white">
              <i class="fas ${icon} text-sm"></i>
            </div>
          </div>
          <div class="flex-1">
            <div class="text-sm text-gray-400 mb-1">
              <span class="font-medium">${name}</span>
              <span class="text-xs text-gray-500 ml-2">
                ${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
              </span>
            </div>
            <div class="text-gray-100 whitespace-pre-wrap">${text}</div>
          </div>
        </div>
      `;
      
      chatMessages.appendChild(messageDiv);
      scrollToBottom();
    }
    
    // Helper function to add loading message
    function addLoadingMessage(id) {
      if (!chatMessages) return;
      
      const loadingDiv = document.createElement('div');
      loadingDiv.id = id;
      loadingDiv.className = 'message-ai bg-gray-800 rounded-lg p-4 mb-4';
      loadingDiv.innerHTML = `
        <div class="flex items-start">
          <div class="flex-shrink-0 mr-3">
            <div class="h-8 w-8 rounded-full bg-purple-600 flex items-center justify-center text-white">
              <i class="fas fa-robot text-sm"></i>
            </div>
          </div>
          <div class="flex-1">
            <div class="text-sm text-gray-400 mb-1">
              <span class="font-medium">Expensio AI</span>
              <span class="text-xs text-gray-500 ml-2">typing...</span>
            </div>
            <div class="flex space-x-2">
              <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 0s"></div>
              <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 0.2s"></div>
              <div class="w-2 h-2 rounded-full bg-gray-400 animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
          </div>
        </div>
      `;
      
      chatMessages.appendChild(loadingDiv);
      scrollToBottom();
    }
    
    // Initial scroll to bottom
    scrollToBottom();
    
    // Focus the input field on page load
    if (chatInput) {
      chatInput.focus();
    }
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input');
    
    if (chatForm) {
      chatForm.addEventListener('submit', (e) => {
        if (!chatInput.value.trim()) {
          e.preventDefault();
          return;
        }
        // Add loading state here if needed
      });
    }
  </script>

  
  

  <!-- Global Lucide Icons Injection -->
  
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>

  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>
</html>
