<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ask Your Finances | Expensio AI</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    * {
      font-family: 'Poppins', sans-serif;
    }

    /* Custom Scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(30, 58, 138, 0.4);
      border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(56, 189, 248, 0.5);
    }

    /* Message Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in-up {
      animation: fadeInUp 0.4s ease-out forwards;
    }
  </style>
</head>

<body class="bg-app text-white flex h-screen overflow-hidden">
  <div class="flex h-screen w-full">

    <!-- ✅ Sidebar -->
    <%- include('partials/sidebar', { activeTab: 'chat' }) %>

      <!-- ✅ Main Content -->
      <main class="flex-1 flex flex-col relative w-full h-full overflow-hidden pattern-bg">

        <!-- Top Glow Effect -->
        <div
          class="absolute top-0 left-1/2 transform -translate-x-1/2 w-3/4 h-32 bg-purple-500/20 blur-[100px] rounded-full pointer-events-none">
        </div>

        <!-- Chat Header -->
        <div
          class="bg-card-custom border-b border-white border-opacity-10 shadow-lg px-8 py-5 z-10 flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <div
              class="bg-gradient-to-tr from-purple-600 to-cyan-500 p-3 rounded-2xl shadow-[0_0_20px_rgba(124,58,237,0.3)]">
              <i data-lucide="bot" class="w-6 h-6 text-white"></i>
            </div>
            <div>
              <h1 class="text-xl font-bold text-gray-100">Expensio AI Assistant</h1>
              <p class="text-sm text-gray-400">Your personal financial advisor, ready to analyze.</p>
            </div>
          </div>
        </div>

        <!-- Chat Messages Container -->
        <div class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar relative z-0 flex flex-col" id="chat-messages">
          <div class="max-w-4xl mx-auto w-full flex-1 flex flex-col">

            <!-- Welcome Message -->
            <div class="flex w-full mb-6 justify-start animate-fade-in-up" id="welcome-message">
              <div class="flex max-w-[90%] md:max-w-[75%] items-end gap-3 group">
                <div class="flex-shrink-0 mb-1 hidden sm:block">
                  <div
                    class="h-10 w-10 rounded-2xl bg-gradient-to-tr from-purple-600 to-cyan-500 flex items-center justify-center text-white shadow-lg shadow-purple-500/20">
                    <i data-lucide="sparkles" class="w-5 h-5"></i>
                  </div>
                </div>
                <div
                  class="bg-card-custom border border-white/10 shadow-xl rounded-2xl rounded-bl-none p-5 backdrop-blur-md relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-cyan-500/5 pointer-events-none">
                  </div>
                  <div class="text-sm text-gray-400 mb-2 font-medium">Expensio AI</div>
                  <div class="text-sm text-gray-200 leading-relaxed">
                    <p>Hello! I'm your AI assistant. I have secure access to your financial data and can help you
                      analyze it.</p>
                    <p class="mt-3 text-gray-400 text-xs uppercase tracking-wider font-semibold">Try asking:</p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      <button type="button" data-q="What did I spend on food this month?"
                        class="quick-q px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs text-cyan-300 hover:text-cyan-200 transition-all cursor-pointer flex items-center gap-1.5">
                        <i data-lucide="utensils" class="w-3.5 h-3.5"></i> Food spending
                      </button>
                      <button type="button" data-q="Show my recent expenses"
                        class="quick-q px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs text-purple-300 hover:text-purple-200 transition-all cursor-pointer flex items-center gap-1.5">
                        <i data-lucide="receipt" class="w-3.5 h-3.5"></i> Recent expenses
                      </button>
                      <button type="button" data-q="How are my budgets looking?"
                        class="quick-q px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg text-xs text-emerald-300 hover:text-emerald-200 transition-all cursor-pointer flex items-center gap-1.5">
                        <i data-lucide="target" class="w-3.5 h-3.5"></i> Budget status
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Dynamic Messages -->
            <div id="current-chat" class="w-full flex flex-col"></div>

          </div>
        </div>

        <!-- Input Area -->
        <div
          class="bg-card-custom border-t border-white border-opacity-10 px-4 py-4 md:px-8 md:py-6 z-10 relative shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.5)] backdrop-blur-xl">
          <div class="max-w-4xl mx-auto relative group">
            <div
              class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-purple-600 rounded-2xl blur opacity-25 group-focus-within:opacity-50 transition duration-500">
            </div>
            <form id="chat-form"
              class="relative flex items-center bg-[#1e293b]/80 backdrop-blur-md border border-white/10 rounded-2xl overflow-hidden p-1.5 shadow-inner">
              <div class="pl-4 text-gray-400">
                <i data-lucide="message-square" class="w-5 h-5 group-focus-within:text-cyan-400 transition-colors"></i>
              </div>
              <input id="chat-input" type="text" name="text" placeholder="Ask anything about your finances..."
                class="w-full px-4 py-3 bg-transparent text-gray-100 placeholder-gray-500 focus:outline-none text-sm md:text-base"
                autocomplete="off" required>
              <button type="submit"
                class="mr-1 p-3 bg-gradient-to-r from-cyan-500 to-purple-600 hover:from-cyan-400 hover:to-purple-500 text-white rounded-xl transition-all duration-300 shadow-lg shadow-cyan-500/25 hover:shadow-cyan-500/40 hover:scale-105 flex items-center justify-center cursor-pointer">
                <i data-lucide="send" class="w-5 h-5 transform translate-x-px translate-y-px"></i>
              </button>
            </form>
            <div class="text-center mt-3 text-[11px] text-gray-500 font-medium">
              Expensio AI uses your aggregated, isolated financial data to provide intelligent insights.
            </div>
          </div>
        </div>

      </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      lucide.createIcons();

      const chatForm = document.getElementById('chat-form');
      const chatInput = document.getElementById('chat-input');
      const chatMessages = document.getElementById('chat-messages');
      const currentChat = document.getElementById('current-chat');
      const welcomeMessage = document.getElementById('welcome-message');

      function scrollToBottom() {
        if (chatMessages) {
          chatMessages.scrollTop = chatMessages.scrollHeight;
        }
      }

      function addMessageToChat(role, text) {
        const messageWrapper = document.createElement('div');
        messageWrapper.className = `flex w-full mb-6 ${role === 'user' ? 'justify-end' : 'justify-start'} animate-fade-in-up`;

        const isAI = role === 'assistant';

        if (isAI) {
          messageWrapper.innerHTML = `
            <div class="flex max-w-[90%] md:max-w-[80%] items-end gap-3 group">
              <div class="flex-shrink-0 mb-1 hidden sm:block">
                <div class="h-8 w-8 rounded-xl bg-gradient-to-tr from-purple-600 to-cyan-500 flex items-center justify-center text-white shadow-lg shadow-purple-500/20">
                  <i data-lucide="bot" class="w-4 h-4"></i>
                </div>
              </div>
              <div class="bg-card-custom border border-white/10 shadow-xl rounded-2xl rounded-bl-none p-4 backdrop-blur-md relative overflow-hidden">
                <div class="text-[11px] text-gray-400 mb-1.5 font-medium">Expensio AI</div>
                <div class="text-sm text-gray-200 leading-relaxed whitespace-pre-wrap message-content"></div>
                <span class="text-[10px] text-gray-500 absolute bottom-2 right-3 opacity-0 group-hover:opacity-100 transition-opacity">${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
              </div>
            </div>
          `;
        } else {
          messageWrapper.innerHTML = `
            <div class="flex max-w-[90%] md:max-w-[80%] items-end gap-3 group flex-row-reverse">
              <div class="bg-gradient-to-br from-cyan-500 to-blue-600 shadow-lg shadow-cyan-500/20 rounded-2xl rounded-br-none p-4 relative">
                <div class="text-[11px] text-white/70 mb-1.5 font-medium text-right">You</div>
                <div class="text-sm text-white leading-relaxed whitespace-pre-wrap message-content"></div>
                <span class="text-[10px] text-white/60 absolute bottom-2 left-3 opacity-0 group-hover:opacity-100 transition-opacity">${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
              </div>
            </div>
          `;
        }

        // Secure text insertion
        messageWrapper.querySelector('.message-content').textContent = text;

        currentChat.appendChild(messageWrapper);
        try {
          if (typeof lucide !== 'undefined') lucide.createIcons();
        } catch (e) {
          console.error("Lucide icon error:", e);
        }
        scrollToBottom();
        return messageWrapper;
      }

      function addLoadingMessage(id) {
        const messageWrapper = document.createElement('div');
        messageWrapper.id = id;
        messageWrapper.className = `flex w-full mb-6 justify-start animate-fade-in-up`;

        messageWrapper.innerHTML = `
          <div class="flex max-w-[90%] md:max-w-[75%] items-end gap-3">
            <div class="flex-shrink-0 mb-1 hidden sm:block">
              <div class="h-8 w-8 rounded-xl bg-gradient-to-tr from-purple-600 to-cyan-500 flex items-center justify-center text-white shadow-lg shadow-purple-500/20">
                <i data-lucide="bot" class="w-4 h-4"></i>
              </div>
            </div>
            <div class="bg-card-custom border border-white/10 shadow-xl rounded-2xl rounded-bl-none p-4 backdrop-blur-md flex flex-col justify-center min-w-[80px] h-[64px]">
              <div class="text-[11px] text-gray-400 mb-1.5 font-medium">Expensio AI</div>
              <div class="flex space-x-1.5 items-center pl-1">
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-purple-400 animate-pulse" style="animation-delay: 0.2s"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" style="animation-delay: 0.4s"></div>
              </div>
            </div>
          </div>
        `;

        currentChat.appendChild(messageWrapper);
        try {
          if (typeof lucide !== 'undefined') lucide.createIcons();
        } catch (e) {
          console.error("Lucide icon error:", e);
        }
        scrollToBottom();
      }

      async function submitChat() {
        console.log("Submit triggered");
        const message = chatInput.value.trim();
        console.log("Message:", message);
        if (!message) return;

        if (welcomeMessage) welcomeMessage.style.display = 'none';

        addMessageToChat('user', message);
        chatInput.value = '';

        const loadingId = 'loading-' + Date.now();
        addLoadingMessage(loadingId);

        try {
          console.log("Starting fetch...");
          const response = await fetch('/chat/message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'text=' + encodeURIComponent(message)
          });

          console.log("Fetch response received. Status:", response.status);

          const loadingEl = document.getElementById(loadingId);
          if (loadingEl) loadingEl.remove();

          if (!response.ok) throw new Error('Server returned ' + response.status);

          const data = await response.json();
          console.log("Parsed JSON:", data);
          console.log("Rendering AI response");
          if (data.success && data.reply) {
            addMessageToChat('assistant', data.reply);
            console.log("Render complete");
          } else {
            throw new Error(data.reply || 'Failed to get valid response');
          }
        } catch (error) {
          console.error('Error sending message:', error);
          const loadingEl = document.getElementById(loadingId);
          if (loadingEl) loadingEl.remove();
          addMessageToChat('assistant', 'Sorry, I encountered an error while processing your request. Please try again later.');
        }
      }

      if (chatForm) {
        chatForm.addEventListener('submit', function (e) {
          e.preventDefault();
          submitChat();
        });
      }

      // Quick question buttons
      document.querySelectorAll('.quick-q').forEach(button => {
        button.addEventListener('click', function () {
          chatInput.value = this.getAttribute('data-q');
          chatInput.focus();
        });
      });

      // Enter key handler
      if (chatInput) {
        chatInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            submitChat();
          }
        });
      }

      scrollToBottom();
    });
  </script>
</body>

</html>