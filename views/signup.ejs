<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signup</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
</head>
<body class="bg-app flex items-center justify-center min-h-screen">

  <form class="bg-card-custom card-hover shadow-xl rounded-2xl w-full max-w-md p-8" action="/create" method="post">
    <h2 class="text-2xl font-bold text-white text-center mb-6">Create Account</h2>

    <input 
      class="bg-opacity-20 border border-white border-opacity-10 text-white font-medium rounded-md w-full p-3 mb-4 outline-none focus:border-cyan-400 transition" 
      type="text" 
      placeholder="Name" 
      name="name"
      required
    >

    <input 
      class="bg-opacity-20 border border-white border-opacity-10 text-white font-medium rounded-md w-full p-3 mb-4 outline-none focus:border-cyan-400 transition" 
      type="email" 
      placeholder="Email" 
      name="email"
      required
    >

    <input 
      class="bg-opacity-20 border border-white border-opacity-10 text-white font-medium rounded-md w-full p-3 mb-4 outline-none focus:border-cyan-400 transition" 
      type="password" 
      placeholder="Password" 
      name="password"
      required
    >

    <input 
      class="bg-opacity-20 border border-white border-opacity-10 text-white font-medium rounded-md w-full p-3 mb-6 outline-none focus:border-cyan-400 transition" 
      type="password" 
      placeholder="Confirm Password" 
      name="confirmpassword"
      required
    >

    <button 
      class="w-full btn-primary text-gray-900 font-semibold rounded-md p-3 transition">
      Create Account
    </button>

    <p class="text-center text-gray-400 mt-4">
      Already have an account? 
      <a class="text-cyan-400 hover:text-cyan-300 hover:underline" href="/login">Login</a>
    </p>
  </form>

</body>
</html>
