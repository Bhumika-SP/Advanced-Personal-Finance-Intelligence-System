<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Trips</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-app text-white flex h-screen">

  <!-- Sidebar -->
  <%- include('partials/sidebar', { activeTab: 'trips' }) %>

  <!-- Main -->
  <main class="flex-1 p-8 overflow-y-auto animate-fade-slide-up delay-100">
    <h2 class="text-2xl font-semibold mb-6">Your Trips</h2>

    <!-- Add Button -->
    <a href="/trips/new" class=" btn-primary  px-4 py-2 rounded-lg mb-6 inline-block">➕ Add Trip</a>

    <!-- Table -->
    <table class="w-full bg-card-custom card-hover rounded-lg overflow-hidden">
      <thead>
        <tr class="text-gray-300">
          <th class="py-3 px-4">Title</th>
          <th class="py-3 px-4">Destination</th>
          <th class="py-3 px-4">Budget</th>
          <th class="py-3 px-4">Start Date</th>
          <th class="py-3 px-4">End Date</th>
          <th class="py-3 px-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (trips && trips.length > 0) { %>
          <% trips.forEach(trip => { %>
            <tr class="border-t border-gray-700">
              <td class="py-2 px-4"><%= trip.title %></td>
              <td class="py-2 px-4"><%= trip.destination %></td>
              <td class="py-2 px-4">₹<%= trip.budget %></td>
              <td class="py-2 px-4"><%= trip.startDate.toDateString() %></td>
              <td class="py-2 px-4"><%= trip.endDate.toDateString() %></td>
              <td class="py-2 px-4 space-x-2">
                <a href="/trips/edit/<%= trip._id %>" class="text-yellow-400 hover:text-yellow-300"><i data-lucide="edit-3" class="w-4 h-4 inline-block mr-1"></i>Edit</a>
                <form action="/trips/delete/<%= trip._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="text-red-500 hover:text-red-400" onclick="return confirm('Delete this trip?')">
                    <i data-lucide="trash-2" class="w-4 h-4 inline-block mr-1"></i>Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="py-4 text-center text-gray-400">No trips yet</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </main>


  
  

  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>
</html>
