<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Trips</title>
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
</head>
<body class="bg-gray-900 text-white flex h-screen">

  <!-- Sidebar -->
  <aside class="w-64 bg-gray-800 p-6 flex flex-col">
      <h1 class="text-2xl font-bold mb-8">Expensio</h1>
      <nav class="space-y-4">
        <a href="/dashboard" class="block hover:text-blue-400">🏠 Home</a>
        <a href="/expenses" class="block hover:text-blue-400">💸 Expenses</a>
        <a href="/income" class="block hover:text-blue-400">💰 Income</a>
        <a href="/trips" class="block hover:text-blue-400">✈️ Trips</a>
        <a href="/savings" class="block hover:text-blue-400">💵 Savings</a>
        <a href="/budgets" class="block hover:text-blue-400">📊 Budgets</a>
        <a href="/subscriptions" class="block hover:text-blue-400">🔁 Subscriptions</a>
        <a href="/chat" class="block hover:text-blue-400">💬 Ask Finances</a>
        <a href="/alerts" class="block hover:text-blue-400">🔔 Alerts</a>
        <hr class="border-gray-700 my-4">
        <a href="/logout" class="block text-red-400 hover:text-red-300">🚪 Logout</a>
      </nav>
    </aside>

  <!-- Main -->
  <main class="flex-1 p-8 overflow-y-auto">
    <h2 class="text-2xl font-semibold mb-6">Your Trips</h2>

    <!-- Add Button -->
    <a href="/trips/new" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg mb-6 inline-block">➕ Add Trip</a>

    <!-- Table -->
    <table class="w-full bg-gray-800 rounded-lg overflow-hidden">
      <thead>
        <tr class="bg-gray-700 text-gray-300">
          <th class="py-3 px-4">Title</th>
          <th class="py-3 px-4">Destination</th>
          <th class="py-3 px-4">Budget</th>
          <th class="py-3 px-4">Start Date</th>
          <th class="py-3 px-4">End Date</th>
          <th class="py-3 px-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (trips && trips.length > 0) { %>
          <% trips.forEach(trip => { %>
            <tr class="border-t border-gray-700">
              <td class="py-2 px-4"><%= trip.title %></td>
              <td class="py-2 px-4"><%= trip.destination %></td>
              <td class="py-2 px-4">₹<%= trip.budget %></td>
              <td class="py-2 px-4"><%= trip.startDate.toDateString() %></td>
              <td class="py-2 px-4"><%= trip.endDate.toDateString() %></td>
              <td class="py-2 px-4 space-x-2">
                <a href="/trips/edit/<%= trip._id %>" class="text-yellow-400 hover:text-yellow-300">✏️ Edit</a>
                <form action="/trips/delete/<%= trip._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="text-red-500 hover:text-red-400" onclick="return confirm('Delete this trip?')">
                    🗑️ Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="py-4 text-center text-gray-400">No trips yet</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </main>

</body>
</html>
