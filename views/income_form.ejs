<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= income ? "Edit Income" : "New Income" %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
</head>
<body class="bg-gray-900 text-white flex h-screen">

  <!-- Sidebar -->
  <aside class="w-64 bg-gray-800 p-6 flex flex-col">
    <h1 class="text-2xl font-bold mb-8">Expensio</h1>
    <nav class="space-y-4">
      <a href="/dashboard" class="block hover:text-blue-400">🏠 Home</a>
      <a href="/expenses" class="block hover:text-blue-400">💸 Expenses</a>
      <a href="/income" class="block text-blue-400">💰 Income</a>
    </nav>
  </aside>

  <!-- Main -->
  <main class="flex-1 p-8">
    <h2 class="text-2xl font-semibold mb-6"><%= income ? "Edit Income" : "New Income" %></h2>

    <form action="<%= income ? '/income/edit/' + income._id : '/income' %>" method="POST" class="space-y-4">
      <div>
        <label class="block mb-1">Source</label>
        <input type="text" name="source" value="<%= income ? income.source : '' %>"
               required class="w-full p-2 rounded bg-gray-800 border border-gray-700">
      </div>

      <div>
        <label class="block mb-1">Description</label>
        <input type="text" name="description" value="<%= income ? income.description : '' %>"
               class="w-full p-2 rounded bg-gray-800 border border-gray-700">
      </div>

      <div>
        <label class="block mb-1">Amount (₹)</label>
        <input type="number" name="amount" value="<%= income ? income.amount : '' %>" required
               class="w-full p-2 rounded bg-gray-800 border border-gray-700">
      </div>

      <button type="submit" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded">
        💾 Save
      </button>
    </form>
  </main>
</body>
</html>
