<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= income ? "Edit Income" : "New Income" %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-app text-white flex h-screen">

  <!-- Sidebar -->
  <%- include('partials/sidebar', { activeTab: 'income_form' }) %>

  <!-- Main -->
  <main class="flex-1 p-8">
    <h2 class="text-2xl font-semibold mb-6"><%= income ? "Edit Income" : "New Income" %></h2>

    <form action="<%= income ? '/income/edit/' + income._id : '/income' %>" method="POST" class="space-y-4">
      <div>
        <label class="block mb-1">Source</label>
        <input type="text" name="source" value="<%= income ? income.source : '' %>"
               required class="w-full p-2 rounded bg-card-custom card-hover border border-gray-700">
      </div>

      <div>
        <label class="block mb-1">Description</label>
        <input type="text" name="description" value="<%= income ? income.description : '' %>"
               class="w-full p-2 rounded bg-card-custom card-hover border border-gray-700">
      </div>

      <div>
        <label class="block mb-1">Amount (₹)</label>
        <input type="number" name="amount" value="<%= income ? income.amount : '' %>" required
               class="w-full p-2 rounded bg-card-custom card-hover border border-gray-700">
      </div>

      <button type="submit" class=" btn-primary  px-4 py-2 rounded">
        💾 Save
      </button>
    </form>
  </main>

  
  

  <!-- Global Lucide Icons Injection -->
  
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>

  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>
</html>
