<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Income</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-app text-white flex h-screen">

  <!-- Sidebar -->
  <!-- <%- include('partials/sidebar', { activeTab: 'income' }) %> -->

  <%- include('partials/sidebar', { activeTab: 'income' }) %>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto animate-fade-slide-up delay-100">
    <h2 class="text-2xl font-semibold mb-6">All Income</h2>

    <a href="/income/new" class=" btn-primary  px-4 py-2 rounded-lg mb-6 inline-block">
      <i data-lucide="plus-circle" class="w-5 h-5 inline-block align-text-bottom mr-1"></i> Add Income
    </a>

    <table class="w-full bg-card-custom card-hover rounded-lg overflow-hidden">
      <thead>
        <tr class="text-gray-300">
          <th class="py-3 px-4">Source</th>
          <th class="py-3 px-4">Description</th>
          <th class="py-3 px-4">Amount</th>
          <th class="py-3 px-4">Date</th>
          <th class="py-3 px-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (incomes && incomes.length > 0) { %>
          <% incomes.forEach(income => { %>
            <tr class="border-t border-gray-700">
              <td class="py-2 px-4"><%= income.source %></td>
              <td class="py-2 px-4"><%= income.description %></td>
              <td class="py-2 px-4">₹<%= income.amount %></td>
              <td class="py-2 px-4"><%= income.date.toDateString() %></td>
              <td class="py-2 px-4 space-x-2">
                <a href="/income/edit/<%= income._id %>" class="text-yellow-400 hover:text-yellow-300"><i data-lucide="edit-3" class="w-4 h-4 inline-block mr-1"></i><i data-lucide="edit" class="w-4 h-4 inline-block align-text-bottom mr-1"></i> Edit</a>
                <form action="/income/delete/<%= income._id %>" method="POST" style="display:inline;">
                  <button type="submit" class="text-red-500 hover:text-red-400"
                          onclick="return confirm('Are you sure you want to delete this income?')">
                    <i data-lucide="trash-2" class="w-4 h-4 inline-block mr-1"></i><i data-lucide="trash-2" class="w-4 h-4 inline-block align-text-bottom mr-1"></i> Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="py-4 text-center text-gray-400">No income records found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </main>

  
  

  <!-- Global Lucide Icons Injection -->
  
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>

  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>
</html>
