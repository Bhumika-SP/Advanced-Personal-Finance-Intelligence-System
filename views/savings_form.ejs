<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= saving ? "Edit Savings" : "New Savings" %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900 text-white flex h-screen">

  <!-- Sidebar -->
  <aside class="w-64 bg-gray-800 p-6 flex flex-col">
    <h1 class="text-2xl font-bold mb-8">Expensio</h1>
    <nav class="space-y-4">
      <a href="/dashboard" class="block hover:text-blue-400">🏠 Home</a>
      <a href="/savings" class="block text-blue-400">💵 Savings</a>
    </nav>
  </aside>

  <!-- Main -->
  <main class="flex-1 p-8">
    <h2 class="text-2xl font-semibold mb-6"><%= saving ? "Edit Savings" : "New Savings" %></h2>

    <form action="<%= saving ? '/savings/edit/' + saving._id : '/savings' %>" method="POST" class="space-y-4">
      <div>
        <label class="block mb-1">Amount (₹)</label>
        <input type="number" name="amount" value="<%= saving ? saving.amount : '' %>" required
          class="w-full p-2 rounded bg-gray-800 border border-gray-700">
      </div>

      <div>
        <label class="block mb-1">Goal</label>
        <input type="text" name="goal" value="<%= saving ? saving.goal : '' %>"
          class="w-full p-2 rounded bg-gray-800 border border-gray-700">
      </div>

      <button type="submit" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded">💾 Save</button>
    </form>
  </main>
</body>
</html>
