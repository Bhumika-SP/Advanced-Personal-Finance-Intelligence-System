<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Expenses</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
  </style>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-app text-white flex h-screen">

  <div class="flex min-h-screen">
  <!-- Sidebar -->
  <%- include('partials/sidebar', { activeTab: 'expenses' }) %>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto animate-fade-slide-up delay-100">
    <h2 class="text-2xl font-semibold mb-6">All Expenses</h2>

    <!-- Add Expense Button -->
    <a href="/expenses/new" class=" btn-primary  px-5 py-3 rounded-lg mb-6 inline-block"><i data-lucide="plus-circle" class="w-5 h-5 inline-block align-text-bottom mr-1"></i> Add Expense</a>

    <!-- Import / Export -->
    <div class="bg-card-custom card-hover rounded-lg p-4 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <form action="/expenses/import" method="POST" enctype="multipart/form-data" class="flex items-center gap-3">
        <input type="file" name="file" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel" class="flex-1 text-sm" required>
        <button class="bg-green-600 hover:bg-green-500 px-4 py-2 rounded">Import</button>
      </form>
      <div class="flex items-center gap-3">
        <label class="text-sm text-gray-300">Month</label>
        <input id="exp-month" type="month" class="p-2 rounded bg-opacity-20">
        <a id="export-csv" href="/expenses/export?format=csv" class="btn-secondary px-4 py-2 rounded">Export CSV</a>
        <a id="export-xlsx" href="/expenses/export?format=xlsx" class="btn-secondary px-4 py-2 rounded">Export XLSX</a>
      </div>
      </div>
    </div>

    <!-- Expenses Table -->
    <div class="overflow-x-auto">
      <table class="min-w-full bg-card-custom card-hover rounded-lg overflow-hidden">
        <thead>
          <tr class="text-gray-300 sticky top-0 z-20">
            <th class="py-3 px-4 cursor-pointer" data-sort="text">Description</th>
            <th class="py-3 px-4 cursor-pointer" data-sort="text">Category</th>
            <th class="py-3 px-4 cursor-pointer" data-sort="number">Amount</th>
            <th class="py-3 px-4 cursor-pointer" data-sort="date">Date</th>
            <th class="py-3 px-4">Actions</th>
          </tr>
        </thead>
        <tbody id="exp-tbody">
          <% if (expenses && expenses.length > 0) { %>
            <% expenses.forEach((expense, i) => { %>
              <tr class="border-t border-gray-700 table-row-hover">
                <td class="py-3 px-4"><%= expense.description %></td>
                <td class="py-3 px-4"><%= expense.category %></td>
                <td class="py-3 px-4" data-value="<%= expense.amount %>">₹<%= expense.amount %></td>
                <td class="py-3 px-4" data-value="<%= expense.date.toISOString().slice(0,10) %>"><%= expense.date.toDateString() %></td>
                <td class="py-3 px-4 space-x-2">
                  <a href="/expenses/edit/<%= expense._id %>" class="text-yellow-400 hover:text-yellow-300 px-2 py-1 inline-block"><i data-lucide="edit-3" class="w-4 h-4 inline-block mr-1"></i>Edit</a>
                  <form action="/expenses/delete/<%= expense._id %>" method="POST" class="inline">
                    <button type="submit" class="text-red-500 hover:text-red-400 px-2 py-1 rounded" onclick="return confirm('Delete this expense?')"><i data-lucide="trash-2" class="w-4 h-4 inline-block mr-1"></i>Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="py-4 text-center text-gray-400">No expenses found</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <script>
      const m = document.getElementById('exp-month');
      const csv = document.getElementById('export-csv');
      const xlsx = document.getElementById('export-xlsx');
      function updateLinks() {
        const baseCsv = '/expenses/export?format=csv';
        const baseX = '/expenses/export?format=xlsx';
        const mm = m && m.value ? `&month=${m.value}` : '';
        if (csv) csv.href = baseCsv + mm;
        if (xlsx) xlsx.href = baseX + mm;
      }
      if (m) {
        m.addEventListener('change', updateLinks);
        updateLinks();
      }

      // Client-side sorting
      const tbody = document.getElementById('exp-tbody');
      const getCellValue = (tr, idx) => tr.children[idx]?.getAttribute('data-value') || tr.children[idx]?.innerText || '';
      function sortBy(idx, type, asc) {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a,b) => {
          const va = getCellValue(a, idx);
          const vb = getCellValue(b, idx);
          if (type === 'number') return (Number(va) - Number(vb)) * (asc ? 1 : -1);
          if (type === 'date') return (new Date(va) - new Date(vb)) * (asc ? 1 : -1);
          return va.localeCompare(vb) * (asc ? 1 : -1);
        });
        rows.forEach(r => tbody.appendChild(r));
      }
      document.querySelectorAll('th[data-sort]').forEach((th, i) => {
        let asc = true;
        th.addEventListener('click', () => {
          sortBy(i, th.getAttribute('data-sort'), asc);
          asc = !asc;
        });
      });
    </script>
  </main>
  </div>

  
  

  <!-- Global Lucide Icons Injection -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });
    // Fallback if already loaded
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  </script>
</body>
</html>
