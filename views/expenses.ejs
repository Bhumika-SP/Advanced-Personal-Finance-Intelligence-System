



<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Expenses</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900 text-white flex h-screen">

  <!-- Sidebar -->
  <aside class="w-64 bg-gray-800 p-6 flex flex-col">
    <h1 class="text-2xl font-bold mb-8">Expensio</h1>
    <nav class="space-y-4">
      <a href="/dashboard" class="block hover:text-blue-400">🏠 Home</a>
      <a href="/expenses" class="block text-blue-400">💸 Expenses</a>
      <a href="/income" class="block hover:text-blue-400">💰 Income</a>
      <a href="/trips" class="block hover:text-blue-400">✈️ Trips</a>
      <a href="/savings" class="block hover:text-blue-400">💵 Savings</a>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-8 overflow-y-auto">
    <h2 class="text-2xl font-semibold mb-6">All Expenses</h2>

    <!-- Add Expense Button -->
    <a href="/expenses/new" class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg mb-6 inline-block">➕ Add Expense</a>

    <!-- Expenses Table -->
    <table class="w-full bg-gray-800 rounded-lg overflow-hidden">
      <thead>
        <tr class="bg-gray-700 text-gray-300">
          <th class="py-3 px-4">Description</th>
          <th class="py-3 px-4">Category</th>
          <th class="py-3 px-4">Amount</th>
          <th class="py-3 px-4">Date</th>
          <th class="py-3 px-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (expenses && expenses.length > 0) { %>
          <% expenses.forEach(expense => { %>
            <tr class="border-t border-gray-700">
              <td class="py-2 px-4"><%= expense.description %></td>
              <td class="py-2 px-4"><%= expense.category %></td>
              <td class="py-2 px-4">₹<%= expense.amount %></td>
              <td class="py-2 px-4"><%= expense.date.toDateString() %></td>
              <td class="py-2 px-4 space-x-2">
                <!-- Edit Button -->
                <a href="/expenses/edit/<%= expense._id %>" class="text-yellow-400 hover:text-yellow-300">✏️ Edit</a>

                <!-- Delete Form -->
                <form action="/expenses/delete/<%= expense._id %>" method="POST" style="display:inline;">
                  <button type="submit" 
                          class="text-red-500 hover:text-red-400"
                          onclick="return confirm('Are you sure you want to delete this expense?')">
                    🗑️ Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="py-4 text-center text-gray-400">No expenses found</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </main>
</body>
</html>
